# Copy this file to terraform.tfvars and replace the placeholder values.

project_id      = "my-gcp-project"
location        = "us-east4"
gcp_oracle_zone = "us-east4-a-r2"

network = "projects/my-gcp-project/global/networks/database-vpc"

labels = {
  terraform = "true"
  example   = "basic"
}

deletion_protection = false

odb_network_id                  = "primary-odb-network"
odb_network_location            = null
odb_network_project_id          = null
odb_network_gcp_oracle_zone     = null
odb_network_labels              = {}
odb_network_deletion_protection = false
odb_network_timeouts = {
  create = "90m"
  update = "60m"
  delete = "60m"
}

client_odb_subnet_id                  = "client-subnet"
client_odb_subnet_cidr_range          = "192.168.1.0/24"
client_odb_subnet_location            = null
client_odb_subnet_project_id          = null
client_odb_subnet_labels              = {}
client_odb_subnet_deletion_protection = false
client_odb_subnet_timeouts = {
  create = "90m"
  update = "60m"
  delete = "60m"
}

backup_odb_subnet_id                  = "backup-subnet"
backup_odb_subnet_cidr_range          = "192.168.2.0/28"
backup_odb_subnet_location            = null
backup_odb_subnet_project_id          = null
backup_odb_subnet_labels              = {}
backup_odb_subnet_deletion_protection = false
backup_odb_subnet_timeouts = {
  create = "90m"
  update = "60m"
  delete = "60m"
}

cloud_exadata_infrastructure_id                  = "primary-exadata"
cloud_exadata_infrastructure_display_name        = "primary-exadata"
cloud_exadata_infrastructure_location            = null
cloud_exadata_infrastructure_project_id          = null
cloud_exadata_infrastructure_gcp_oracle_zone     = null
cloud_exadata_infrastructure_labels              = {}
cloud_exadata_infrastructure_deletion_protection = false
cloud_exadata_infrastructure_timeouts = {
  create = "300m"
  update = "180m"
  delete = "180m"
}

exadata_shape         = "Exadata.X11M"
compute_count         = 2
storage_count         = 3
total_storage_size_gb = null
customer_contacts = [
  {
    email = "dba@example.com"
  }
]
exadata_maintenance_window = null

cloud_vm_cluster_id = "primary-vm-cluster"
display_name        = "primary-vm-cluster"
timeouts = {
  create = "180m"
  update = "90m"
  delete = "90m"
}

license_type               = "BRING_YOUR_OWN_LICENSE"
cpu_core_count             = 4
node_count                 = 2
ocpu_count                 = 2
memory_size_gb             = 60
db_node_storage_size_gb    = 120
data_storage_size_tb       = 2
disk_redundancy            = "HIGH"
local_backup_enabled       = false
sparse_diskgroup_enabled   = false
cluster_name               = "basic"
diagnostics_events_enabled = true
health_monitoring_enabled  = true
incident_logs_enabled      = true
time_zone_id               = "UTC"
time_zone_version          = null
gi_version                 = "23.0.0.0"
hostname_prefix            = "exa"
db_server_ocids            = null

ssh_public_keys = [
  "ssh-rsa AAAA... user@example.com"
]
